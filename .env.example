# RallyMind AI 生产环境配置

# 服务器配置
HOST=0.0.0.0
PORT=8000

# Worker 配置
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker

# 上传配置
MAX_UPLOAD_SIZE=100MB
UPLOAD_DIR=uploads

# CORS 配置
CORS_ORIGINS=*

# 日志配置
LOG_LEVEL=info
ACCESS_LOG=true

# 安全配置
SECRET_KEY=your-secret-key-change-in-production

# 性能配置
KEEPALIVE=5
TIMEOUT=30
GRACEFUL_TIMEOUT=30
MAX_REQUESTS=1000
